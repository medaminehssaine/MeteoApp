%% ==========================================
%% ACTIVITY DIAGRAM 4: Action Blocking Flow
%% ==========================================

graph TD
    StartBlock([Membre déclare blocage]) --> InputReason[Saisir raison + type de blocage<br/>RESOURCE / DEPENDENCY / TECHNICAL / DECISION]
    InputReason --> UpdateAction[Mettre à jour action<br/>status = BLOCKED<br/>blocked_since = NOW()]
    UpdateAction --> RecalcProgress[Recalculer avancement module<br/>et avancement projet]

    RecalcProgress --> CheckCriticalPath{Action sur le<br/>chemin critique?}
    CheckCriticalPath -- Oui --> HighAlert[Alerte HAUTE PRIORITÉ<br/>→ Directeur + Chef]
    CheckCriticalPath -- Non --> NormalAlert[Alerte normale<br/>→ Chef de projet]

    HighAlert --> CheckDuration
    NormalAlert --> CheckDuration

    CheckDuration{Bloquée depuis<br/>> 5 jours?}
    CheckDuration -- Oui --> TriggerR20[Déclencher règle R20<br/>→ Forçage ORAGE potentiel]
    CheckDuration -- Non --> Monitor[Surveiller quotidiennement]

    TriggerR20 --> CheckCorrectiveAction{Action corrective<br/>existe?}
    Monitor --> CheckCorrectiveAction
    CheckCorrectiveAction -- Non --> SuggestAction[Recommander création<br/>d'action corrective]
    CheckCorrectiveAction -- Oui --> TrackAction[Suivre l'action corrective]

    SuggestAction --> RecalcMeteo[Recalculer météo]
    TrackAction --> RecalcMeteo
    RecalcMeteo --> EndBlock([Fin])

    style HighAlert fill:#f8d7da
    style TriggerR20 fill:#f8d7da
    style SuggestAction fill:#fff4e1

