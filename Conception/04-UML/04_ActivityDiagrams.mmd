%% ==========================================
%% ACTIVITY DIAGRAM 3: CQD Calculation
%% ==========================================

graph TD
    StartCQD([Trigger: Recalcul CQD]) --> LoadProject[Charger données projet<br/>budget, actions, indicateurs]

    LoadProject --> CalcCost[COÛT<br/>écart = (consommé/prévu - 1) × 100]
    LoadProject --> CalcQuality[QUALITÉ<br/>score = moyenne indicateurs QUALITY]
    LoadProject --> CalcDelay[DÉLAI<br/>écart = (avancement_réel/prévu - 1) × 100]

    CalcCost --> DetCostState{écart_coût}
    DetCostState -- "≤ 5%" --> CostAligned[ALIGNED]
    DetCostState -- "≤ 15%" --> CostTension[UNDER_TENSION]
    DetCostState -- "> 15%" --> CostDegraded[DEGRADED]

    CalcQuality --> DetQualState{score_qualité}
    DetQualState -- "≥ 70" --> QualAligned[ALIGNED]
    DetQualState -- "≥ 50" --> QualTension[UNDER_TENSION]
    DetQualState -- "< 50" --> QualDegraded[DEGRADED]

    CalcDelay --> DetDelayState{écart_délai}
    DetDelayState -- "≥ -5%" --> DelayAligned[ALIGNED]
    DetDelayState -- "≥ -15%" --> DelayTension[UNDER_TENSION]
    DetDelayState -- "< -15%" --> DelayDegraded[DEGRADED]

    CostAligned --> CalcTrends
    CostTension --> CalcTrends
    CostDegraded --> CalcTrends
    QualAligned --> CalcTrends
    QualTension --> CalcTrends
    QualDegraded --> CalcTrends
    DelayAligned --> CalcTrends
    DelayTension --> CalcTrends
    DelayDegraded --> CalcTrends

    CalcTrends[Calculer TENDANCES<br/>comparer 3 dernières mesures<br/>IMPROVING / STABLE / DETERIORATING] --> SaveCQD[Sauvegarder CQDHistory]
    SaveCQD --> InvalidateCQDCache[Invalider cache CQD]
    InvalidateCQDCache --> EndCQD([Fin])

    style CostAligned fill:#d4edda
    style CostTension fill:#fff4e1
    style CostDegraded fill:#f8d7da
    style QualAligned fill:#d4edda
    style QualTension fill:#fff4e1
    style QualDegraded fill:#f8d7da
    style DelayAligned fill:#d4edda
    style DelayTension fill:#fff4e1
    style DelayDegraded fill:#f8d7da

