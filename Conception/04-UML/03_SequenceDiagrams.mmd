%% ==========================================
%% SEQUENCE DIAGRAM 3: AI Projection Generation
%% ==========================================

sequenceDiagram
    actor Director as Directeur
    participant UI as Angular App
    participant Ctrl as ProjectionController
    participant PSvc as ProjectionService
    participant L1 as TrendAnalyzer
    participant L2 as PlanSimulator
    participant L3 as ActionPlanEvaluator
    participant L4 as RiskIntegrator
    participant L5 as CapacityAnalyzer
    participant Comp as ProjectionCompositor
    participant Conf as ConfidenceCalculator
    participant Scen as ScenarioGenerator
    participant Expl as ExplanationEngine
    participant Reco as RecommendationEngine
    participant DB as PostgreSQL
    participant Cache as Redis

    Director->>UI: Consulter projections J+14
    UI->>Ctrl: GET /api/v1/projects/{pid}/projections?horizon=14
    Ctrl->>Cache: get("projection:project:{pid}:14")

    alt Cache hit
        Cache-->>Ctrl: cached Projection
        Ctrl-->>UI: 200 ProjectionResponse
    end

    Ctrl->>PSvc: generateProjection(projectId, 14)

    par Layer 1: Trend Analysis
        PSvc->>L1: analyzeTrend(project, 14)
        L1->>DB: load indicator history (max 10 points each)
        L1->>L1: Weighted Moving Average per indicator
        L1->>L1: Linear Regression (slope + R²)
        L1->>L1: Project values at J+14
        L1->>L1: Calculate data quality factor
        L1-->>PSvc: TrendResult(score=72.5, confidence=0.75)
    and Layer 2: Plan Simulation
        PSvc->>L2: simulatePlan(project, 14)
        L2->>DB: load actions + dependencies
        L2->>L2: Build DAG
        L2->>L2: Find critical path
        L2->>L2: Calculate velocity (14-day window)
        L2->>L2: Monte Carlo × 100 simulations
        L2->>L2: Analyze distribution (mean, P25, P75)
        L2-->>PSvc: SimulationResult(score=68.3, confidence=0.70)
    and Layer 3: Action Plan Evaluation
        PSvc->>L3: evaluateActionPlan(project)
        L3->>DB: load indicators in WARNING/ALERT/CRITICAL
        L3->>DB: load corrective actions
        L3->>L3: Check coverage (indicator → actions)
        L3->>L3: Evaluate action effectiveness
        L3-->>PSvc: ActionPlanResult(score=55.0, confidence=0.65)
    and Layer 4: Risk Integration
        PSvc->>L4: integrateRisks(project, 14)
        L4->>DB: load active risks
        L4->>L4: Calculate exposure per risk
        L4->>L4: Apply status adjustments
        L4->>L4: Apply category×horizon factors
        L4->>L4: Normalize total exposure
        L4-->>PSvc: RiskResult(score=62.0, confidence=0.70)
    and Layer 5: Capacity Analysis
        PSvc->>L5: analyzeCapacity(project, 14)
        L5->>DB: load remaining actions
        L5->>DB: count active team members
        L5->>L5: Calculate load ratio
        L5->>L5: Adjust with resource indicators
        L5-->>PSvc: CapacityResult(score=72.0, confidence=0.60)
    end

    PSvc->>Comp: compose(trend, simulation, actionPlan, risk, capacity)

    Comp->>Comp: weightedScore = 72.5×0.30 + 68.3×0.25 + 55.0×0.20 + 62.0×0.15 + 72.0×0.10
    Note right of Comp: = 21.75 + 17.08 + 11.00 + 9.30 + 7.20<br/>= 66.33

    Comp->>Comp: projectedMeteo = convertToMeteo(66.33) → NUAGE_CHARGE

    Comp->>Conf: calculate(components, horizon=14)
    Conf->>Conf: layerConfidence = weighted avg → 0.70
    Conf->>Conf: coherence (stdDev=6.8 < 10) → 1.0
    Conf->>Conf: horizonFactor(14) → 0.85
    Conf->>Conf: dataFactor(12 points) → 0.85
    Conf->>Conf: final = 0.70×0.35 + 1.0×0.25 + 0.85×0.25 + 0.85×0.15
    Note right of Conf: = 0.245 + 0.25 + 0.2125 + 0.1275<br/>= 0.835 → 83.5% → HIGH
    Conf-->>Comp: ConfidenceResult(level=HIGH, pct=83.5)

    Comp->>Scen: generate(66.33, trend, simulation, risk)
    Scen->>Scen: nominal(66.33) → NUAGE_CHARGE
    Scen->>Scen: optimistic(66.33 + 12.5 = 78.8) → NUAGE_CLAIR
    Scen->>Scen: pessimistic(66.33 - 18.2 = 48.1) → ORAGE
    Scen-->>Comp: Scenarios(nominal, optimistic, pessimistic)

    Comp->>Reco: generate(context)
    Reco->>Reco: Check 6 recommendation rules
    Reco->>Reco: Sort by priority, limit to 5
    Reco-->>Comp: List<Recommendation>

    Comp->>Expl: generate(context)
    Expl->>Expl: Template-based NLG
    Expl-->>Comp: explanation string

    Comp-->>PSvc: Projection

    PSvc->>DB: save Projection
    PSvc->>Cache: set("projection:project:{pid}:14", result, TTL=15min)
    PSvc-->>Ctrl: Projection

    Ctrl-->>UI: 200 ProjectionResponse
    UI-->>Director: Afficher dashboard projection

---

%% ==========================================
%% SEQUENCE DIAGRAM 4: Create Project + Full Setup
%% ==========================================

sequenceDiagram
    actor Dir as Directeur
    participant UI as Angular App
    participant PC as ProjectController
    participant PS as ProjectService
    participant MS as ModuleService
    participant IS as ProjectIndicatorService
    participant RS as UserProjectRoleService
    participant DB as PostgreSQL
    participant Audit as AuditService

    Dir->>UI: Remplir formulaire création projet
    UI->>PC: POST /api/v1/projects<br/>{name, code, dates, budget, type, criticality, ...}

    PC->>PS: createProject(request, currentUser)
    PS->>PS: Validate project data
    PS->>DB: check unique name
    PS->>DB: check unique code
    PS->>DB: save Project(status=PREPARATION)
    DB-->>PS: saved Project

    PS->>RS: assignRole(director, project, DIRECTOR)
    RS->>DB: save UserProjectRole

    PS->>Audit: log(CREATE, PROJECT, projectId)
    PS-->>PC: ProjectResponse

    PC-->>UI: 201 {project}
    UI-->>Dir: Projet créé, configurer modules

    Dir->>UI: Ajouter Module "Backend API"
    UI->>PC: POST /api/v1/projects/{pid}/modules<br/>{name: "Backend API", weight: 40, ...}
    PC->>MS: createModule(projectId, request)
    MS->>MS: Validate weight (total <= 100)
    MS->>DB: save Module
    MS-->>PC: ModuleResponse
    PC-->>UI: 201 {module}

    Dir->>UI: Sélectionner indicateurs depuis bibliothèque
    UI->>PC: POST /api/v1/projects/{pid}/indicators<br/>{indicatorLibraryId: "PRG-001", weight: 30, criticality: HIGH}
    PC->>IS: addIndicator(projectId, request)
    IS->>DB: load IndicatorLibrary(PRG-001)
    IS->>IS: Copy default thresholds
    IS->>IS: Set criticality coefficient (HIGH → 1.5)
    IS->>DB: save ProjectIndicator
    IS-->>PC: ProjectIndicatorResponse
    PC-->>UI: 201 {indicator}

    Note over Dir,UI: Répéter pour chaque module et indicateur

    Dir->>UI: Affecter Chef Projet
    UI->>PC: POST /api/v1/projects/{pid}/team<br/>{userId: "chef-uuid", role: "CHEF"}
    PC->>RS: assignRole(chef, project, CHEF)
    RS->>DB: save UserProjectRole
    PC-->>UI: 200 OK

    Dir->>UI: Valider périmètre → status = IN_PROGRESS
    UI->>PC: PATCH /api/v1/projects/{pid}/status<br/>{status: "IN_PROGRESS"}
    PC->>PS: updateStatus(projectId, IN_PROGRESS)
    PS->>PS: Validate: has modules, has indicators, has chef
    PS->>DB: update project status
    PS->>Audit: log(UPDATE, PROJECT, projectId, "Status → IN_PROGRESS")
    PS-->>PC: ProjectResponse
    PC-->>UI: 200 {project with status IN_PROGRESS}

