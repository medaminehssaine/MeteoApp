%% ==========================================
%% SEQUENCE DIAGRAM 5: Forcing Rules Evaluation
%% ==========================================

sequenceDiagram
    participant MSvc as MeteoCalculationService
    participant FRE as ForcingRuleEngine
    participant DB as PostgreSQL

    MSvc->>FRE: evaluate(project)

    Note over FRE: R20: Actions bloquées > 5 jours
    FRE->>DB: SELECT COUNT(*) FROM actions<br/>WHERE project_id = ? AND status = 'BLOCKED'<br/>AND blocked_since < NOW() - INTERVAL '5 days'
    DB-->>FRE: count = 2

    alt count >= 1
        FRE->>FRE: addRule(R20, "2 actions bloquées > 5 jours")
    end

    Note over FRE: R21: >= 30% actions en retard
    FRE->>DB: SELECT<br/>  COUNT(*) FILTER (WHERE planned_end < NOW() AND status != 'COMPLETED') as late,<br/>  COUNT(*) as total<br/>FROM actions WHERE project_id = ?
    DB-->>FRE: late=4, total=20 → 20%

    alt ratio >= 30%
        FRE->>FRE: addRule(R21, "X% actions en retard")
    end

    Note over FRE: R22: Budget > 120%
    FRE->>DB: SELECT budget_consumed, budget_total FROM projects WHERE id = ?
    DB-->>FRE: consumed=150000, total=200000 → 75%

    alt consumed/total > 120%
        FRE->>FRE: addRule(R22, "Budget à X%")
    end

    Note over FRE: R23: Indicateur CRITICAL sans action corrective
    FRE->>DB: SELECT pi.* FROM project_indicators pi<br/>WHERE pi.current_score < 20<br/>AND NOT EXISTS (SELECT 1 FROM corrective_actions ca<br/>  WHERE ca.indicator_id = pi.id AND ca.status IN ('OPEN','IN_PROGRESS'))
    DB-->>FRE: 1 indicator found

    alt count >= 1
        FRE->>FRE: addRule(R23, "Indicateur RSK-002 CRITICAL sans action")
    end

    Note over FRE: R24: Aucune mise à jour > 10 jours
    FRE->>DB: SELECT last_update_at FROM projects WHERE id = ?
    DB-->>FRE: last_update_at = 3 days ago

    alt daysWithoutUpdate > 10
        FRE->>FRE: addRule(R24, "Aucune MAJ depuis X jours")
    end

    FRE-->>MSvc: ForcingResult(forced=true, rules=[R20, R23],<br/>forcedMeteo=ORAGE,<br/>explanation="Forçage ORAGE: 2 actions bloquées > 5j,<br/>indicateur RSK-002 CRITICAL sans action corrective")
