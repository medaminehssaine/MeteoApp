%% ==========================================
%% SEQUENCE DIAGRAM 1: Authentication Flow
%% ==========================================

sequenceDiagram
    actor User as Chef Projet
    participant UI as Angular App
    participant Int as JWT Interceptor
    participant Auth as AuthController
    participant Svc as AuthService
    participant JWT as JwtTokenProvider
    participant DB as PostgreSQL
    participant Redis as Redis Cache

    User->>UI: Saisir email + password
    UI->>Auth: POST /api/v1/auth/login<br/>{email, password}
    Auth->>Svc: authenticate(loginRequest)
    Svc->>DB: findByEmail(email)
    DB-->>Svc: User entity

    alt User locked
        Svc-->>Auth: throw AccountLockedException
        Auth-->>UI: 401 "Compte verrouillé"
    end

    Svc->>Svc: BCrypt.matches(password, hash)

    alt Invalid password
        Svc->>DB: incrementFailedAttempts()
        alt failedAttempts >= 5
            Svc->>DB: lockAccount(30 minutes)
        end
        Svc-->>Auth: throw BadCredentialsException
        Auth-->>UI: 401 "Identifiants invalides"
    end

    Svc->>DB: resetFailedAttempts()
    Svc->>DB: updateLastLoginAt()
    Svc->>JWT: generateAccessToken(user, 1h)
    JWT-->>Svc: accessToken
    Svc->>JWT: generateRefreshToken(user, 7d)
    JWT-->>Svc: refreshToken
    Svc->>DB: saveRefreshToken(token)
    Svc-->>Auth: AuthResponse
    Auth-->>UI: 200 {accessToken, refreshToken, user, expiresIn}
    UI->>UI: Store tokens in memory
    UI-->>User: Redirect to Dashboard

    Note over UI,Auth: --- Subsequent API Calls ---

    User->>UI: Navigate to project
    UI->>Int: GET /api/v1/projects
    Int->>Int: Add "Authorization: Bearer <token>"
    Int->>Auth: Request with JWT header
    Auth->>JWT: validateToken(token)
    JWT-->>Auth: UserPrincipal
    Auth-->>UI: 200 {projects: [...]}

    Note over UI,Auth: --- Token Refresh ---

    UI->>Int: GET /api/v1/projects (token expired)
    Int->>Auth: Request with expired JWT
    Auth-->>Int: 401 Token expired
    Int->>Auth: POST /api/v1/auth/refresh<br/>{refreshToken}
    Auth->>Svc: refreshAccessToken(refreshToken)
    Svc->>DB: findRefreshToken(token)
    Svc->>JWT: generateAccessToken(user, 1h)
    Svc-->>Auth: new accessToken
    Auth-->>Int: 200 {accessToken}
    Int->>Int: Retry original request with new token
    Int->>Auth: GET /api/v1/projects (new token)
    Auth-->>UI: 200 {projects: [...]}

---

%% ==========================================
%% SEQUENCE DIAGRAM 2: Record Indicator Value + Météo Recalculation
%% ==========================================

sequenceDiagram
    actor Chef as Chef Projet
    participant UI as Angular App
    participant Ctrl as IndicatorController
    participant ISvc as ProjectIndicatorService
    participant MSvc as MeteoCalculationService
    participant FRE as ForcingRuleEngine
    participant CSvc as CQDCalculationService
    participant DB as PostgreSQL
    participant Cache as Redis

    Chef->>UI: Saisir valeur indicateur PRG-001 = 72%
    UI->>Ctrl: POST /api/v1/projects/{pid}/indicators/{iid}/values<br/>{value: 72, comment: "Sprint 5 terminé"}

    Ctrl->>ISvc: recordValue(projectId, indicatorId, value, comment)

    ISvc->>ISvc: Validate value (R1: 0-100)
    ISvc->>ISvc: calculateScore(72, thresholds)
    Note right of ISvc: thresholds: G=90, O=75, R=50<br/>72 >= 50 (rouge) et < 75 (orange)<br/>score = 50 + (72-50)/(75-50) × 30<br/>score = 50 + 26.4 = 76

    ISvc->>ISvc: determineState(76) → GOOD
    ISvc->>DB: save IndicatorValueHistory(value=72, score=76, state=GOOD)
    ISvc->>DB: update ProjectIndicator(currentValue=72, currentScore=76)
    ISvc-->>Ctrl: IndicatorValueResponse

    Ctrl->>MSvc: recalculate(projectId)  [ASYNC]
    Note right of Ctrl: Returns 200 immediately

    MSvc->>DB: loadAllActiveIndicators(projectId)
    DB-->>MSvc: List<ProjectIndicator> (e.g. 8 indicators)

    loop For each indicator
        MSvc->>MSvc: weightedScore = score × weight × critCoeff
    end

    MSvc->>MSvc: projectScore = Σ(weightedScores) / Σ(weights × critCoeffs)
    Note right of MSvc: Example: projectScore = 71.3

    MSvc->>MSvc: rawMeteo = convertToMeteo(71.3) → NUAGE_CLAIR

    MSvc->>FRE: evaluate(project)
    FRE->>DB: count blocked actions > 5 days
    FRE->>DB: count late actions (%)
    FRE->>DB: check budget variance
    FRE->>DB: check CRITICAL indicators without action
    FRE->>DB: check last update date

    alt Any forcing rule triggered
        FRE-->>MSvc: ForcingResult(forced=true, rules=[R20], meteo=ORAGE)
        MSvc->>MSvc: finalMeteo = ORAGE (forced)
    else No forcing
        FRE-->>MSvc: ForcingResult(forced=false)
        MSvc->>MSvc: finalMeteo = NUAGE_CLAIR
    end

    MSvc->>MSvc: generateExplanation(project, scores, forcing)
    MSvc->>DB: save MeteoHistory(score=71.3, meteo=NUAGE_CLAIR, ...)
    MSvc->>Cache: invalidate("meteo:project:{pid}")
    MSvc->>Cache: invalidate("dashboard:*")

    par CQD Recalculation
        Ctrl->>CSvc: recalculate(projectId) [ASYNC]
        CSvc->>DB: load project budget data
        CSvc->>CSvc: costVariance = (consumed/planned - 1) × 100
        CSvc->>CSvc: qualityScore = avg(QUALITY indicators)
        CSvc->>CSvc: delayVariance = (actual/planned - 1) × 100
        CSvc->>CSvc: determine C/Q/D states
        CSvc->>CSvc: calculate trends (last 3 entries)
        CSvc->>DB: save CQDHistory
        CSvc->>Cache: invalidate("cqd:project:{pid}")
    end

    Ctrl-->>UI: 201 {value, score, state}
    UI-->>Chef: Indicateur mis à jour ✓

