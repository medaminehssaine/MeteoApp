{
  "buildCommand": "npm run build -- --configuration=production",
  "outputDirectory": "dist/meteo-app/browser",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/proxy?path=$1"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
